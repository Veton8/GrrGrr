PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/grgr
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage: local | r2 | s3
STORAGE_TYPE=local

# Cloudflare R2 (when STORAGE_TYPE=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=grgr-videos
R2_PUBLIC_URL=

# AWS S3 (when STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=grgr-videos

# Bull-Board admin dashboard (leave blank for open access in dev)
ADMIN_API_KEY=

# Content moderation
MODERATION_ENABLED=true
OPENAI_API_KEY=your-openai-api-key

# LiveKit — real-time video streaming
# Get free credentials at https://cloud.livekit.io
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=wss://your-project.livekit.cloud
